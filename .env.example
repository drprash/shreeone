# Copy to .env and replace with your own strong values

# Used by docker-compose for Postgres and backend DATABASE_URL interpolation
DB_HOST=db
DB_PORT=5432
DB_NAME=shreeone
DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_db_password

# JWT signing key (generate at least 32 random bytes hex)
SECRET_KEY=change_me_to_a_long_random_secret

# Optional explicit backend settings (for non-compose local runs)
FRONTEND_URL=http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7