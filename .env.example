# Copy to .env and replace with your own strong values

# Core
DB_HOST=db
DB_PORT=5432
DB_NAME=shreeone
DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_db_password

# JWT signing key (generate at least 32 random bytes hex)
SECRET_KEY=change_me_to_a_long_random_secret

FRONTEND_URL=http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local AI - Ollama (docker compose --profile ollama up -d)
# Defaults are already set in docker-compose.yml; only uncomment to override.
# LLM_BASE_URL=http://llm:11434
# LLM_MODEL=gemma4:e4b
# LLM_TIMEOUT_SECONDS=90

# Cloud AI providers (docker compose up -d, no --profile needed)
# Uncomment and fill ONE provider block, then set LLM_PROVIDER to match.

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# LLM_PROVIDER=google
# GOOGLE_AI_API_KEY=...
# GOOGLE_AI_MODEL=gemini-2.0-flash
